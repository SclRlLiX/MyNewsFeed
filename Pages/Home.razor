@page "/"
@using MyNewsFeed.Components
@using MyNewsFeed.Models
@using MyNewsFeed.Services
@inject RssService RssService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>MyNewsFeed</PageTitle>

@* This invisible div tells us when we've scrolled away from the top *@
<div id="top-sentinel" class="h-1 w-full"></div>


<div class="flex justify-between items-center mb-4 mt-2 px-2">
    @* Date and Time Column *@
    <div class="flex flex-col">
        
        @* Date and Clock Component  *@
        <DateAndClock/>

        @* Last refresh timestamp — sits below the clock *@
        <span class="font-jb-mono text-[9px] uppercase tracking-[0.15em] text-gray-600 mt-1">
            @(_lastUpdated.HasValue ? $"Last Updated {_lastUpdated.Value:HH:mm}" : "")
        </span>
    </div>

    @* Refresh Button - Only Show when articles have been loaded  *@
    @if (_isAppReady)
    {
        <div class="flex flex-col items-end">
            <button @onclick="RefreshNews"
            disabled="@_isRefreshing"
            class="group flex items-center gap-2 mt-4 bg-white/5 border border-white/10 px-4 py-2 rounded-full hover:bg-white/10 transition-all active:scale-95 disabled:opacity-50">

                @* The Refresh Icon *@
                <svg xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 text-blue-400 @(_isRefreshing ? "animate-spin" : "group-hover:rotate-180 transition-transform duration-500")"
                fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>

                <span class="font-jb-mono text-[10px] font-bold uppercase tracking-[0.2em] text-gray-300">
                    @(_isRefreshing ? "Shuffling..." : "Shuffle")
                </span>
            </button>
        </div>
    }
</div>

@* Search Bar — hidden during initial load, nothing to search yet *@
@if(_isAppReady)
{
    <div class="px-2 mb-4">
        <div class="relative flex items-center">

            @* Search Icon *@
            <svg xmlns="http://www.w3.org/2000/svg"
                 class="absolute left-3 h-4 w-4 text-gray-500 pointer-events-none"
                 fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
            </svg>

            @* Input *@
            <input type="text"
                   placeholder="SEARCH ARTICLES..."
                   value="@_searchQuery"
                   @oninput="HandleSearch"
                   class="search-input w-full bg-white/5 border border-white/10 rounded-full
            pl-9 pr-9 py-2
            font-jb-mono text-[16px] uppercase 
            text-gray-300 placeholder-gray-600
            focus:outline-none focus:border-white/25 focus:bg-white/[0.07]
            transition-all duration-200" />

            @* Clear Button — only visible when there's text *@
            @if (!string.IsNullOrEmpty(_searchQuery))
            {
                <button @onclick="ClearSearch" class="absolute right-3 text-gray-600 hover:text-gray-400 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         class="h-3.5 w-3.5"
                         fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            }

        </div>
    </div>
}

@* categories *@
@if (_isAppReady)
{
    <div class="flex items-center gap-2 overflow-x-auto pb-2 w-full scrollbar-hide mb-2">

        @* New Button *@
        <button id="pill-New" @onclick='() => HandlePillClick("New", "pill-New")' class="px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap transition-colors button-pill
        @(_activeFilter == "New" ? "bg-gray-100 text-gray-900" : "bg-transparent border border-gray-600 text-gray-300 hover:bg-gray-800")">
            New
        </button>

        @* All Button *@
        <button id="pill-All" @onclick='() => HandlePillClick("All", "pill-All")' class="px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap transition-colors button-pill
        @(_activeFilter == "All" ? "bg-gray-100 text-gray-900" : "bg-transparent border border-gray-600 text-gray-300 hover:bg-gray-800")">
            All
        </button>


        @* Category Buttons *@
        @foreach (var category in Categories)
        {
            var id = $"pill-{category}";
            <button id="@id" @onclick='() => HandlePillClick(category, id)' class="px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap transition-colors button-pill
            @(_activeFilter == category ? "bg-gray-100 text-gray-900" : "bg-transparent border border-gray-600 text-gray-300 hover:bg-gray-800")">
                @category
            </button>
        }
    </div>
}


@* cards *@
<div id="cards">
    <div class="mx-auto w-full grid grid-cols-2 gap-2 auto-rows-[250px]">

        @if (articles == null)
        {
            @* Skeleton — 1 big card + 2 small cards, repeating *@
            @for (int s = 0; s < 3; s++)
            {
                @* Big skeleton card *@
                <div class="col-span-2 rounded bg-gray-800 animate-pulse overflow-hidden relative">
                    <div class="absolute inset-0 bg-gradient-to-br from-gray-700/40 to-gray-800"></div>
                    <div class="absolute top-3 left-3 h-5 w-20 bg-white/10 rounded"></div>
                    <div class="absolute top-3 right-3 h-5 w-14 bg-white/10 rounded"></div>
                    <div class="absolute bottom-0 left-0 w-full p-3 space-y-2">
                        <div class="h-4 bg-white/10 rounded w-11/12"></div>
                        <div class="h-4 bg-white/10 rounded w-4/5"></div>
                        <div class="h-3 bg-white/[0.06] rounded w-2/3 mt-1"></div>
                    </div>
                </div>

                @* Two small skeleton cards *@
                <div class="col-span-1 rounded bg-gray-800 animate-pulse overflow-hidden relative">
                    <div class="absolute inset-0 bg-gradient-to-br from-gray-700/30 to-gray-800"></div>
                    <div class="absolute top-3 left-3 h-4 w-16 bg-white/10 rounded"></div>
                    <div class="absolute bottom-0 left-0 w-full p-3 space-y-2">
                        <div class="h-3 bg-white/10 rounded w-full"></div>
                        <div class="h-3 bg-white/10 rounded w-3/4"></div>
                    </div>
                </div>
                <div class="col-span-1 rounded bg-gray-800 animate-pulse overflow-hidden relative">
                    <div class="absolute inset-0 bg-gradient-to-br from-gray-700/30 to-gray-800"></div>
                    <div class="absolute top-3 left-3 h-4 w-16 bg-white/10 rounded"></div>
                    <div class="absolute bottom-0 left-0 w-full p-3 space-y-2">
                        <div class="h-3 bg-white/10 rounded w-full"></div>
                        <div class="h-3 bg-white/10 rounded w-4/5"></div>
                    </div>
                </div>
            }
        }
        else
        {
            @foreach (var chunk in ArticleChunks.Take(_visibleChunks))
            {
                bool isEvenRowSet = chunk.Index % 2 == 0;

                @for (int i = 0; i < chunk.Items.Count; i++)
                {
                    var article = chunk.Items[i];


                    if (i == 0)
                    {
                        //big card
                        <div class="relative col-span-2 overflow-hidden rounded bg-gray-800">

                            @* image *@
                            <img src="@article.ImageUrl" alt="Article image" class="absolute inset-0 h-full w-full object-cover" />

                            @* source tag *@
                            <div class="absolute top-4 left-4 z-20">
                                <span class="glass-tag font-tag text-tag bg-black/10 border border-white/10 text-white uppercase tracking-widest px-2 py-1 rounded">
                                    @article.Source
                                </span>
                            </div>

                            @* date tag *@
                            <div class="absolute top-3 right-3 z-10">
                                <span class="glass-tag font-tag text-tag bg-black/10 border border-white/10 px-2 py-1 rounded uppercase tracking-widest">
                                    @GetTimeAgo(article.PublishedDate)
                                </span>
                            </div>

                            <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-black via-black/70 to-transparent"></div>
                            <div class="absolute bottom-0 left-0 w-full p-3 flex flex-col justify-end">
                                @* Headline *@
                                <a href="@article.Link"
                                       @onclick="() => OpenModal(article)"
                                       @onclick:preventDefault
                                       class="font-headline text-headline font-bold line-clamp-3 text-white no-underline cursor-pointer">
                                    @article.Headline
                                </a>

                                @* Description *@
                                <p class="font-description text-description text-gray-300 line-clamp-2">
                                    @article.Description
                                </p>
                            </div>
                        </div>
                    }
                    else
                    {
                        // Fill the row if this is the only small card in the chunk
                        bool isOrphan = chunk.Items.Count == 2 && i == 1;
                        string colSpan = isOrphan ? "col-span-2" : "col-span-1";
                        
                        // Zig-zag pattern
                        bool showImage = (i == 1 && isEvenRowSet) || (i == 2 && !isEvenRowSet);

                        if (showImage)
                        {
                            //small card with image and headline only
                            <div class="relative col-span-1 h-full overflow-hidden rounded-lg bg-gray-800">

                                @* image *@
                                <img src="@article.ImageUrl" alt="" class="absolute inset-0 h-full w-full object-cover" />
                                <div class="absolute inset-x-0 bottom-0 h-3/4 bg-gradient-to-t from-black/90 via-black/50 to-transparent"></div>

                                @* source tag *@
                                <div class="absolute top-3 left-3 z-10">
                                    <span class="glass-tag font-tag text-tag bg-black/10 border border-white/10 px-2 py-1 rounded uppercase tracking-widest">
                                        @article.Source
                                    </span>
                                </div>

                                @* date tag *@
                                <div class="absolute top-3 right-3 z-10">
                                    <span class="glass-tag font-tag text-tag bg-black/10 border border-white/10 px-2 py-1 rounded uppercase tracking-widest">
                                        @GetTimeAgo(article.PublishedDate)
                                    </span>
                                </div>

                                <div class="absolute bottom-0 left-0 w-full p-3 flex flex-col justify-end">

                                    @* Headline *@
                                    <a href="@article.Link"
                                           @onclick="() => OpenModal(article)"
                                           @onclick:preventDefault
                                           class="font-headline text-headline-small font-bold text-white line-clamp-4 no-underline cursor-pointer">
                                        @article.Headline
                                    </a>
                                </div>
                            </div>
                        }
                        else
                        {
                            //small card text only
                            <div class="col-span-1 h-full bg-gradient-to-br from-gray-800 to-gray-900 border border-white/[0.07] p-3 flex flex-col rounded-lg overflow-hidden">

                                @* Source chip — top, mirrors image card layout *@
                                <span class="inline-flex items-center font-tag text-tag bg-white/5 border border-white/10 text-gray-400 uppercase tracking-widest px-2 py-1 rounded self-start">
                                    @article.Source
                                </span>

                                @* Headline + description — vertically centered in remaining space *@
                                <div class="flex-1 flex flex-col justify-center py-2">
                                    <a href="@article.Link"
                                           @onclick="() => OpenModal(article)"
                                           @onclick:preventDefault
                                           class="font-headline text-headline-small font-bold text-white line-clamp-4 no-underline cursor-pointer transition-colors duration-200">
                                        @article.Headline
                                    </a>

                                    <p class="font-description text-description text-gray-500 line-clamp-3 mt-1">
                                        @article.Description
                                    </p>
                                </div>

                                @* Date — anchored to bottom *@
                                <div class="pt-2 border-t border-white/[0.06] flex justify-end">
                                    <span class="font-tag text-tag text-gray-600 uppercase tracking-widest">
                                        @GetTimeAgo(article.PublishedDate)
                                    </span>
                                </div>

                            </div>
                        }
                    }
                }
            }

            @if (ArticleChunks.Count == 0)
            {
                <div class="col-span-2 flex flex-col items-center justify-center py-16 px-4 gap-4">

                    @* Icon *@
                    <div class="h-14 w-14 rounded-full bg-white/5 border border-white/10 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="h-6 w-6 text-gray-600"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                  d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v8a2 2 0 01-2 2z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                  d="M9 13h6M9 17h4" />
                        </svg>
                    </div>

                    @* Text *@
                    <div class="flex flex-col items-center gap-1 text-center">
                        <span class="font-jb-mono text-[11px] uppercase tracking-[0.2em] text-gray-400">
                            No Articles Found
                        </span>
                        <span class="font-description text-[11px] text-gray-600">
                            @(string.IsNullOrWhiteSpace(_searchQuery)
                                ? "Nothing recent in this category."
                                : $"No results for \"{_searchQuery}\"")
                        </span>
                    </div>

                    @* Clear Search Button — only when searching *@
                    @if (!string.IsNullOrWhiteSpace(_searchQuery))
                    {
                        <button @onclick="ClearSearch"
                                class="mt-1 font-jb-mono text-[10px] uppercase tracking-[0.15em] text-blue-400
                            hover:text-blue-300 transition-colors">
                            Clear search
                        </button>
                    }
                </div>
            }

            @* Load More *@
            @if (ArticleChunks.Count > _visibleChunks)
            {
                <div @ref="observerTarget" class="h-10 w-full"></div>
            }

            @* OpenModal *@
            @if (_selectedArticle != null)
            {
                <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/90 p-4 @(_isClosing ? "animate-backdrop-out" : "animate-backdrop")" @onclick="CloseModal">
        
                    @* The Expanded Card *@
                    <div class="bg-gray-900 rounded-2xl overflow-hidden max-w-lg w-full shadow-2xl border border-white/10 flex flex-col max-h-[90vh] [transform:translateZ(0)] @(_isClosing ? "animate-modal-out" : "animate-modal")" @onclick:stopPropagation>

                        @* 1. Top Image Section (Mirrors your Big Card) *@
                        <div class="relative h-64 w-full shrink-0 overflow-hidden bg-gray-900 mb-[-1px]">
                            <img src="@_selectedArticle.ImageUrl" class="absolute inset-0 h-full w-full object-cover" />

                            @* Gradient to ensure text readability if the image is bright at the bottom *@
                            <div class="absolute inset-x-0 bottom-[-1px] h-[calc(50%+1px)] bg-gradient-to-t from-gray-900 to-transparent"></div>

                            @* Source tag *@
                            <div class="absolute top-4 left-4 z-20">
                                <span class="glass-tag bg-black/10 border border-white/10 text-white text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded shadow-sm">
                                    @_selectedArticle.Source
                                </span>
                            </div>

                            @* date tag *@
                            <div class="absolute top-3 right-3 z-10">
                                <span class="glass-tag font-tag text-tag bg-black/10 border border-white/10 px-2 py-1 rounded uppercase tracking-widest">
                                    @GetTimeAgo(_selectedArticle.PublishedDate)
                                </span>
                            </div>

                        </div>

                        @* 2. Content Section (Scrollable if the text is very long) *@
                        <div class="p-6 overflow-y-auto">

                            <a href="@_selectedArticle.Link" target="_blank"
                                   class="font-headline-secondary text-2xl font-bold text-white leading-tight tracking-tight  transition-colors block mb-3">
                                @_selectedArticle.Headline
                            </a>

                            <p class="font-description text-sm text-gray-500 leading-snug">
                                @_selectedArticle.Description
                            </p>

                            @* Full Date *@
                            <div class="mt-4 pt-3 border-t border-white/[0.06] flex items-center gap-2">
                                <span class="font-tag text-[9px] text-gray-600 uppercase tracking-[0.25em]">Published</span>
                                <span class="font-jb-mono text-[9px] text-gray-500 tracking-[0.1em]">
                                    @_selectedArticle.PublishedDate.ToString("MMM dd, yyyy · HH:mm")
                                </span>
                            </div>

                        </div>

                    </div>
                </div>
            }

        }

        @* FAB - Only Show when articles have been loaded  *@
        @if (_isAppReady)
        {
            <div class="fixed top-6 left-1/2 -translate-x-1/2 z-50 transition-all duration-300
            @(_showFloatingButton
                             ? "opacity-100 translate-y-0 pointer-events-auto"
                             : "opacity-0 -translate-y-4 pointer-events-none")">

                <button @onclick="RefreshAndScrollUp"
                disabled="@_isRefreshing"
                class="group flex items-center gap-2 bg-gray-900/90 backdrop-blur-md border border-white/20 px-4 py-2 rounded-full hover:bg-gray-800 hover:border-white/40 transition-all shadow-2xl active:scale-95 disabled:opacity-50">

                    <svg xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 text-blue-400 @(_isRefreshing ? "animate-spin" : "group-hover:rotate-180 transition-transform duration-500")"
                    fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>

                    <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-white">
                        @(_isRefreshing ? "Shuffling..." : "New Articles")
                    </span>
                </button>
            </div>
        }
    </div>
</div>


@code {


    //Vars 
    private List<Article>? articles;
    private int _visibleChunks = 5; // Shows 15 articles initially
    private bool _isAppReady = false;

    #region Initial App Load 
    protected override async Task OnInitializedAsync()
    {
        await FetchNewsAsync();
        SetFilter("New");
        _lastUpdated = DateTime.Now;
        _isAppReady = true;   // only true once articles + chunks are both ready
        StateHasChanged();    // trigger the final render with everything ready
    }
    #endregion

    #region Fetching Articles 
    private async Task FetchNewsAsync()
    {
        var fetchTasks = _feeds.Select(f => RssService.GetArticlesAsync(f.Url, f.Name, f.Category));
        var results = await Task.WhenAll(fetchTasks);

        var arr = results.SelectMany(a => a)
            .Where(a => !string.IsNullOrWhiteSpace(a.ImageUrl) &&
                        !a.Link.Contains("buyside", StringComparison.OrdinalIgnoreCase))
            .DistinctBy(a => (
                a.Headline.Trim().ToLowerInvariant(),
                a.Description.Trim().ToLowerInvariant()
            ))
            .ToArray();

        Random.Shared.Shuffle(arr);
        articles = [.. arr];
    }
    #endregion

    

    #region Reshuffle Button
    private bool _isRefreshing = false;
    private DateTime? _lastUpdated;

    private async Task RefreshNews()
    {
        if (_isRefreshing) return;

        _isRefreshing = true;
        StateHasChanged(); // Triggers your loading spinner

        await FetchNewsAsync(); // Re-download and shuffle everything
        SetFilter(_activeFilter); // Re-apply the CURRENT tab and reset chunks

        _isRefreshing = false;
        _lastUpdated = DateTime.Now;
        StateHasChanged();
    }
    #endregion

    #region Search

    private string _searchQuery = "";

    private void HandleSearch(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? "";
        RebuildChunks();
    }

    private void ClearSearch()
    {
        _searchQuery = "";
        RebuildChunks();
    }

    // Extracted so both SetFilter and search can call it
    private void RebuildChunks()
    {
        _visibleChunks = 5;
        _isObserverInitialized = false;

        // Disconnect the old bottom observer — its target element is about to be removed from the DOM
        JS.InvokeVoidAsync("observerInterop.disconnectBottom");

        ArticleChunks = DisplayedArticles
            .Chunk(3)
            .Select((items, index) => (index, items.ToList()))
            .ToList();

        StateHasChanged();
    }

    #endregion


    #region Categories
    private string _activeFilter = "New";
    private IEnumerable<Article> DisplayedArticles
    {
        get
        {
            // Guard: nothing to show if articles haven't loaded yet
            if (articles == null)
            {
                return Enumerable.Empty<Article>();
            }

            // Step 1 — Apply the active category filter
            IEnumerable<Article> filteredArticles;

            if (_activeFilter == "New")
            {
                // "New" means published within the last 12 hours
                DateTime twelveHoursAgo = DateTime.Now.AddHours(-12);
                filteredArticles = articles.Where(a => a.PublishedDate >= twelveHoursAgo);
            }
            else if (Categories.Contains(_activeFilter))
            {
                // A specific category is selected — match on the Category field
                filteredArticles = articles.Where(a => a.Category == _activeFilter);
            }
            else
            {
                // "All" or any unknown filter — return everything
                filteredArticles = articles;
            }

            // Step 2 — Apply the search query on top of the category filter
            bool hasSearchQuery = !string.IsNullOrWhiteSpace(_searchQuery);

            if (hasSearchQuery)
            {
                filteredArticles = filteredArticles.Where(a =>
                    a.Headline.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    a.Description.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));
            }

            // Step 3 — Sort: newest first for category/all tabs, keep shuffle for "New"
            return _activeFilter == "New"
                ? filteredArticles.OrderByDescending(a => a.PublishedDate)
                : filteredArticles;

        }
    }

    private void SetFilter(string filter)
    {
        _activeFilter = filter;
        RebuildChunks();
    }

    //center category pill
    private async Task HandlePillClick(string category, string elementId)
    {
        // Run your core engine to update the articles
        SetFilter(category);
    
        // Run the visual effect to center the pill
        // A tiny delay ensures the DOM is ready before the scroll starts
        await Task.Delay(10);
        await JS.InvokeVoidAsync("scrollToElement", elementId);
    }

    #endregion


    # region Article Cards

    // --- CARDS ---

    // Normal property to prevent re-rendering loops
    private List<(int Index, List<Article> Items)> ArticleChunks { get; set; } = new();

    private const string ProxyBase = "https://corsproxy.io/?url=";

    private static readonly string[] Categories = {"Top Stories", "World", "Business", "Finance", "Technology", "Sports", "Weather" };

    private readonly (string Name, string Category, string Url)[] _feeds =
    {

        
        ("WELT", Categories[0], $"{ProxyBase}https://www.welt.de/feeds/topnews.rss"),
        ("WELT", Categories[0], $"{ProxyBase}https://www.welt.de/feeds/latest.rss"),
        ("WELT", Categories[2], $"{ProxyBase}https://www.welt.de/feeds/section/wirtschaft.rss"),
        ("WELT", Categories[5], $"{ProxyBase}https://www.welt.de/feeds/section/sport.rss"),

        ("DW", Categories[0], $"{ProxyBase}https://rss.dw.com/xml/rss-de-all"),

        ("FAZ", Categories[0], $"{ProxyBase}https://www.faz.net/rss/aktuell/"),
        ("FAZ", Categories[1], $"{ProxyBase}https://www.faz.net/rss/aktuell/politik/"),
        ("FAZ", Categories[2], $"{ProxyBase}https://www.faz.net/rss/aktuell/wirtschaft/"),
        ("FAZ", Categories[3], $"{ProxyBase}https://www.faz.net/rss/aktuell/finanzen/"),
        ("FAZ", Categories[4], $"{ProxyBase}https://www.faz.net/rss/aktuell/technik-motor/"),
        ("FAZ", Categories[5], $"{ProxyBase}https://www.faz.net/rss/aktuell/sport/"),

        ("NYT", Categories[0], $"{ProxyBase}https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml"),
        ("NYT", Categories[1], $"{ProxyBase}https://rss.nytimes.com/services/xml/rss/nyt/World.xml"),
