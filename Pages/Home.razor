@page "/"
@using MyNewsFeed.Models
@using MyNewsFeed.Services
@inject RssService RssService
@inject IJSRuntime JS

<PageTitle>MyNewsFeed</PageTitle>


<div class="flex justify-between items-center mb-8 mt-2 px-2">
    @* Date and Time Column *@
    <div class="flex flex-col">
        @* The Date: Small, Wide, and Colorful *@
        <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-blue-500 mb-1">
            @DateTime.Now.ToString("dddd, MMMM dd")
        </span>
        
        @* The Time: Large, Bold, and Tabular *@
        <h1 class="font-jb-mono text-4xl font-black text-white tabular-nums">
            @DateTime.Now.ToString("HH:mm")<span class="text-xl text-gray-500 ml-1">@DateTime.Now.ToString("ss")</span>
        </h1>
    </div>

    <button @onclick="RefreshNews"
            disabled="@_isRefreshing"
            class="group flex items-center gap-2 mt-4 bg-white/5 border border-white/10 px-4 py-2 rounded-full hover:bg-white/10 transition-all active:scale-95 disabled:opacity-50">
        
        @* The Refresh Icon *@
        <svg xmlns="http://www.w3.org/2000/svg"
             class="h-4 w-4 text-blue-400 @(_isRefreshing ? "animate-spin" : "group-hover:rotate-180 transition-transform duration-500")"
             fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>

        <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-gray-300">
            @(_isRefreshing ? "Shuffling..." : "Shuffle")
        </span>
    </button>
</div>


<div id="cards">
    <div class="mx-auto w-full grid grid-cols-2 gap-2 auto-rows-[250px]">

        @if (articles == null)
        {
            <div class="col-span-2 text-white text-center mt-10">Loading feed...</div>
        }
        else
        {
            @foreach (var chunk in ArticleChunks.Take(_visibleChunks))
            {
                bool isEvenRowSet = chunk.Index % 2 == 0;

                @for (int i = 0; i < chunk.Items.Count; i++)
                {
                    var article = chunk.Items[i];


                    if (i == 0)
                    {
                        //big card
                        <div class="relative col-span-2 overflow-hidden rounded bg-gray-800">

                            @* image *@
                            <img src="@article.ImageUrl" alt="Article image" class="absolute inset-0 h-full w-full object-cover" />

                            @* source tag *@
                            <div class="absolute top-3 left-3 z-10">
                                <span class="font-tag text-tag bg-black/10 backdrop-blur-md border border-white/10 px-2 py-1 rounded uppercase tracking-widest">
                                    @article.Source
                                </span>
                            </div>

                            @* date tag *@
                            <div class="absolute top-3 right-3 z-10">
                                <span class="font-tag text-tag bg-black/10 backdrop-blur-md border border-white/10 px-2 py-1 rounded uppercase tracking-widest">
                                    @GetTimeAgo(article.PublishedDate)
                                </span>
                            </div>

                            <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-black via-black/70 to-transparent"></div>
                            <div class="absolute bottom-0 left-0 w-full p-3 flex flex-col justify-end">
                                @* Headline *@
                                <a href="@article.Link"
                                       @onclick="() => OpenModal(article)"
                                       @onclick:preventDefault
                                       class="font-headline text-headline font-bold line-clamp-3 text-white no-underline cursor-pointer">
                                    @article.Headline
                                </a>

                                @* Description *@
                                <p class="font-description text-description text-gray-300 line-clamp-2">
                                    @article.Description
                                </p>
                            </div>
                        </div>
                    }
                    else
                    {
                        // Fill the row if this is the only small card in the chunk
                        bool isOrphan = chunk.Items.Count == 2 && i == 1;
                        string colSpan = isOrphan ? "col-span-2" : "col-span-1";
                        
                        // Zig-zag pattern
                        bool showImage = (i == 1 && isEvenRowSet) || (i == 2 && !isEvenRowSet);

                        if (showImage)
                        {
                            //small card with image and headline only
                            <div class="relative col-span-1 h-full overflow-hidden rounded-lg bg-gray-800">

                                @* image *@
                                <img src="@article.ImageUrl" alt="" class="absolute inset-0 h-full w-full object-cover" />
                                <div class="absolute inset-x-0 bottom-0 h-3/4 bg-gradient-to-t from-black/90 via-black/50 to-transparent"></div>

                                @* source tag *@
                                <div class="absolute top-3 left-3 z-10">
                                    <span class="font-tag text-tag bg-black/10 backdrop-blur-md border border-white/10 px-2 py-1 rounded uppercase tracking-widest">
                                        @article.Source
                                    </span>
                                </div>

                                @* date tag *@
                                <div class="absolute top-3 right-3 z-10">
                                    <span class="font-tag text-tag bg-black/10 backdrop-blur-md border border-white/10 px-2 py-1 rounded uppercase tracking-widest">
                                        @GetTimeAgo(article.PublishedDate)
                                    </span>
                                </div>

                                <div class="absolute bottom-0 left-0 w-full p-3 flex flex-col justify-end">

                                    @* Headline *@
                                    <a href="@article.Link"
                                           @onclick="() => OpenModal(article)"
                                           @onclick:preventDefault
                                           class="font-headline text-headline-small font-bold text-white line-clamp-4 no-underline cursor-pointer">
                                        @article.Headline
                                    </a>
                                </div>
                            </div>
                        }
                        else
                        {
                            //small card text only
                            <div class="col-span-1 h-full bg-gray-900 p-3 flex flex-col rounded-lg">

                                @* Headline *@
                                <div>
                                    <a href="@article.Link"
                                           @onclick="() => OpenModal(article)"
                                           @onclick:preventDefault
                                           class="font-headline-text-only text-headline-small font-bold text-white line-clamp-4 mb-2 no-underline cursor-pointer">
                                        @article.Headline
                                    </a>
                                
                                    @* Description *@
                                    <p class="font-description text-description text-gray-300 line-clamp-5 justify-bottom">
                                        @article.Description
                                    </p>
                                </div>
                                

                                @* Badge for Text-Only Card (Using a subtle border) *@
                                <div class="mt-auto pt-4 flex justify-between items-center">

                                    @* source tag *@
                                    <span class="font-tag text-tag border border-white/20 text-gray-500 uppercase tracking-widest px-2 py-1 rounded">
                                        @article.Source
                                    </span>

                                    @* date tag *@
                                    <span class="font-tag text-tag border border-white/20 text-gray-500 uppercase tracking-widest px-2 py-1 rounded">
                                        @GetTimeAgo(article.PublishedDate)
                                    </span>
                                
                                </div>
                                


                            </div>
                        }
                    }
                }
            }

            @* Load More *@
            @if (ArticleChunks.Count > _visibleChunks)
            {
                <div @ref="observerTarget" class="h-10 w-full"></div>
            }

            @* OpenModal *@
            @if (_selectedArticle != null)
            {
                <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/90 p-4 @(_isClosing ? "animate-backdrop-out" : "animate-backdrop")" @onclick="CloseModal">
        
                    @* The Expanded Card *@
                    <div class="bg-gray-900 rounded-2xl overflow-hidden max-w-lg w-full shadow-2xl border border-white/10 flex flex-col max-h-[90vh] @(_isClosing ? "animate-modal-out" : "animate-modal")" @onclick:stopPropagation>
            
                        @* 1. Top Image Section (Mirrors your Big Card) *@
                        <div class="relative h-64 w-full shrink-0">
                            <img src="@_selectedArticle.ImageUrl" class="absolute block align-bottom inset-0 h-[calc(100%+1px)] w-full object-cover" />
    
                            @* Gradient to ensure text readability if the image is bright at the bottom *@
                            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-gray-900 to-transparent"></div>
    
                            @* Source tag *@
                            <div class="absolute top-4 left-4 z-20">
                                <span class="bg-black/10 backdrop-blur-md border border-white/10 text-white text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded shadow-sm">
                                    @_selectedArticle.Source
                                </span>
                            </div>

                            @* date tag *@
                            <div class="absolute top-3 right-3 z-10">
                                <span class="font-tag text-tag bg-black/10 backdrop-blur-md border border-white/10 px-2 py-1 rounded uppercase tracking-widest">
                                    @GetTimeAgo(_selectedArticle.PublishedDate)
                                </span>
                            </div>

                        </div>

                        @* 2. Content Section (Scrollable if the text is very long) *@
                        <div class="p-6 overflow-y-auto">
                            @* Headline is now a direct link *@
                            <a href="@_selectedArticle.Link" target="_blank"
                                   class="font-headline-text-only text-3xl font-bold text-white leading-tight hover:text-blue-400 transition-colors block mb-4">
                                @_selectedArticle.Headline
                            </a>

                            <p class="font-description text-l text-gray-300">
                                @_selectedArticle.Description
                            </p>

                            @* Full Date: Pushed to the bottom of the content area *@
                            <div class="pt-4">
                                <p class="font-jb-mono text-[10px] text-gray-500 uppercase tracking-[0.2em] font-medium">
                                    - @_selectedArticle.PublishedDate.ToString("dddd, MMMM dd, yyyy")
                                </p>
                            </div>

                        </div>


                        @* 3. Action Footer *@
                        @* <div class="p-4 bg-black/20 flex justify-between items-center">
                            <button @onclick="CloseModal" class="text-gray-500 hover:text-white text-xs font-bold uppercase tracking-widest">
                                Close
                            </button>
                            <a href="@_selectedArticle.Link" target="_blank" class="text-blue-500 font-bold text-xs uppercase tracking-widest hover:text-blue-400">
                                Read Full Story
                            </a>
                        </div> *@

                    </div>
                </div>
            }

        }
    </div>
</div>


@code {

    //clock
    private string _time = DateTime.Now.ToString("HH:mm:ss");
    private System.Timers.Timer? _timer;

    protected override void OnInitialized()
    {
        // Update every 1 second (1000ms)
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += (s, e) =>
        {
            _time = DateTime.Now.ToString("HH:mm:ss");
            InvokeAsync(StateHasChanged); // Forces the UI to refresh
        };
        _timer.Start();
    }

    // Always dispose of timers to prevent memory leaks
    public void Dispose() => _timer?.Dispose();


    // --- CARDS ---
    private List<Article>? articles;
    private int _visibleChunks = 5; // Shows 15 articles initially

    // Normal property to prevent re-rendering loops
    private List<(int Index, List<Article> Items)> ArticleChunks { get; set; } = new();

    private const string ProxyBase = "https://corsproxy.io/?url=";

    private readonly (string Name, string Url)[] _feeds =
    {
        ("FAZ", $"{ProxyBase}https://www.faz.net/rss/aktuell/"),
        ("FAZ", $"{ProxyBase}https://www.faz.net/rss/aktuell/wirtschaft/"),
        ("NYT", $"{ProxyBase}https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml"),
        ("NYT", $"{ProxyBase}https://rss.nytimes.com/services/xml/rss/nyt/World.xml"),
        ("NYT", $"{ProxyBase}https://rss.nytimes.com/services/xml/rss/nyt/AsiaPacific.xml"),
        ("NYT", $"{ProxyBase}https://rss.nytimes.com/services/xml/rss/nyt/Europe.xml"),
        ("NYT", $"{ProxyBase}https://rss.nytimes.com/services/xml/rss/nyt/MiddleEast.xml"),
        ("NYT", $"{ProxyBase}https://rss.nytimes.com/services/xml/rss/nyt/US.xml"),
        ("WSJ", $"{ProxyBase}https://feeds.content.dowjones.io/public/rss/WSJcomUSBusiness"),
        ("WSJ", $"{ProxyBase}https://feeds.content.dowjones.io/public/rss/RSSMarketsMain"),
        ("WSJ", $"{ProxyBase}https://feeds.content.dowjones.io/public/rss/RSSWSJD"),
        ("WSJ", $"{ProxyBase}https://feeds.content.dowjones.io/public/rss/RSSWorldNews"),
        ("FT",  $"{ProxyBase}https://www.ft.com/myft/following/7ea4d910-3fb7-4a6c-bda3-e2f5f9b3b14b.rss")
    };

    protected override async Task OnInitializedAsync()
    {
        // Pass both pieces of data from the Tuple to the service
        var fetchTasks = _feeds.Select(f => RssService.GetArticlesAsync(f.Url, f.Name));

        var results = await Task.WhenAll(fetchTasks);

        // Merge all lists
        articles = results.SelectMany(a => a)
        //Filter for images AND exclude "buyside" links
        .Where(a => !string.IsNullOrWhiteSpace(a.ImageUrl) &&
                    !a.Link.Contains("buyside", StringComparison.OrdinalIgnoreCase))
    
        //Shuffle the filtered list
        .OrderBy(_ => Random.Shared.Next())
        .ToList();
    
        if (articles != null)
        {
            ArticleChunks = articles
                .Chunk(3)
                .Select((items, index) => (index, items.ToList()))
                .ToList();
        }
    }

    private string GetTimeAgo(DateTime dateTime)
    {
        var span = DateTime.Now - dateTime;
        if (span.TotalDays > 1) return $"{(int)span.TotalDays}d ago";
        if (span.TotalHours > 1) return $"{(int)span.TotalHours}h ago";
        if (span.TotalMinutes > 1) return $"{(int)span.TotalMinutes}m ago";
        return "Just now";
    }


    private bool _isRefreshing = false;

    private async Task RefreshNews()
    {
        if (_isRefreshing) return; // Prevent double-clicks

        _isRefreshing = true;
    
        // This re-runs your existing fetching, filtering, and shuffling logic
        await OnInitializedAsync();

        _isRefreshing = false;
        StateHasChanged(); // Tells Blazor to "repaint" the UI with the new shuffle
    }


    private void LoadMore()
    {
        _visibleChunks += 10; // Adds 20 more articles per click
    }

    // 1. Add these two variables
    private ElementReference observerTarget;
    private DotNetObjectReference<Home>? dotNetHelper; // Change 'YourComponentName' to the actual name of your .razor file!

    // 2. Add OnAfterRenderAsync to start the observer
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetHelper = DotNetObjectReference.Create(this);
        }
        
        // Re-attach observer when the tracker renders
        if (ArticleChunks.Count > _visibleChunks && observerTarget.Context != null)
        {
            await JS.InvokeVoidAsync("observerInterop.initialize", dotNetHelper, observerTarget);
        }
    }

    // 3. Mark LoadMore with [JSInvokable] so JavaScript can fire it
    [JSInvokable]
    public void TriggerLoadMore()
    {
        _visibleChunks += 5;
        StateHasChanged(); // Tell Blazor to draw the new items
    }


    //Modal
    // Declare the state variables
    private Article? _selectedArticle;
    private bool _isClosing = false;

    // Open stays simple
    private void OpenModal(Article article) => _selectedArticle = article;

    // Close must be the ASYNC version only
    private async Task CloseModal()
    {
        if (_isClosing) return; // Prevent double-clicks during animation

        _isClosing = true;
        StateHasChanged();

        // Wait for your CSS "animate-modal-out" to finish
        await Task.Delay(200);

        _selectedArticle = null;
        _isClosing = false;
        StateHasChanged();
    }
}